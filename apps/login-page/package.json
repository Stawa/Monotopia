{
  "name": "login-page",
  "scripts": {
    "bun": "cross-env RUNTIME_ENV=bun bun run --bun",
    "node": "cross-env RUNTIME_ENV=node node",
    "tsx": "cross-env RUNTIME_ENV=node tsx",
    "dev": "cross-env RUNTIME_ENV=node tsx watch src/index.ts || cross-env RUNTIME_ENV=bun bun run --bun src/index.ts",
    "setup": "cross-env RUNTIME_ENV=node tsx scripts/setup.ts || cross-env RUNTIME_ENV=bun bun run --bun scripts/setup.ts",
    "clean": "rimraf .cache dist",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@antfu/ni": "^30.1.0",
    "@monotopia/config": "workspace:*",
    "@monotopia/const": "workspace:*",
    "@monotopia/db": "workspace:*",
    "@monotopia/logger": "workspace:*",
    "@monotopia/types": "workspace:*",
    "@monotopia/utils": "workspace:*",
    "@hono/node-server": "^2.0.4",
    "bcryptjs": "^3.0.3",
    "cross-env": "^10.1.0",
    "hono": "^4.12.23",
    "jsonwebtoken": "^9.0.3",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "author": "Stawa",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  }
}
