{
  "name": "monotopia",
  "private": true,
  "version": "3.2.0",
  "description": "Monotopia, a Growtopia private server built with Node.js and Bun.js, powered by growtopia.js",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "fix:lint": "pnpm lint:fix",
    "fix": "pnpm format && pnpm lint:fix",
    "give:role": "pnpm --filter server give:role",
    "reset:world": "pnpm --filter server reset:world",
    "mobile:dns": "node scripts/mobile-dns.cjs",
    "ipv6:proxy": "node scripts/ipv6-udp-proxy.cjs",
    "setup": "turbo run setup",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "author": "Stawa",
  "contributors": [
    "Stawa",
    "JadlionHD <jadlion.dev@gmail.com> (https://github.com/JadlionHD)",
    "badewen (https://github.com/badewen)",
    "GorgonUK (https://github.com/GorgonUK)",
    "Mikasuru (https://github.com/Mikasuru)",
    "dearminder (https://github.com/dearminder)",
    "ZTance1 (https://github.com/ZTance1)",
    "Phoenix-rat (https://github.com/Phoenix-rat)",
    "jeffryafandi (https://github.com/jeffryafandi)",
    "iRestartz (https://github.com/iRestartz)",
    "Ritshu (https://github.com/Ritshu)",
    "sanderDijkxhoorn (https://github.com/sanderDijkxhoorn)",
    "GTPSHAX (https://github.com/GTPSHAX)",
    "Chadgamer2023 (https://github.com/Chadgamer2023)",
    "KalebChristian (https://github.com/KalebChristian)",
    "mario-fuckan (https://github.com/mario-fuckan)",
    "JustPandaEver (https://github.com/JustPandaEver)",
    "swagesh (https://github.com/swagesh)",
    "Roxaro (https://github.com/Roxaro)",
    "Shulej (https://github.com/Shulej)",
    "Willi-js (https://github.com/Willi-js)",
    "Zeeetu (https://github.com/Zeeetu)"
  ],
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=20.19.0"
  }
}
